# Port Configuration - Change these to avoid conflicts with other apps
FRONTEND_PORT=8099
BACKEND_PORT=3099

# URLs - Update these for production deployment
FRONTEND_URL=http://localhost:8099

# Google Custom Search API (optional - enables web image search)
# 1. Get an API key: https://console.cloud.google.com/apis/credentials
#    - Enable "Custom Search JSON API" in your project
# 2. Create a search engine: https://programmablesearchengine.google.com
#    - Enable "Image search" in the search engine settings
#    - Set "Search the entire web" to ON
# Free tier: 100 queries/day
GOOGLE_API_KEY=
GOOGLE_CX=
